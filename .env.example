# Copy to .env and edit. The harness works with ANY provider — cloud API or local.

# Which backend to use: anthropic | openai | ollama
LLM_PROVIDER=ollama

# Model id (examples per provider):
#   anthropic -> claude-opus-4-8
#   openai    -> gpt-4o-mini   (or any OpenAI-compatible / OpenRouter model)
#   ollama    -> llama3.2
LLM_MODEL=llama3.2

# API key — required for cloud providers (anthropic / openai / openrouter). Leave blank for Ollama.
LLM_API_KEY=

# Base URL — override to point at ANY endpoint, cloud or LOCAL:
#   OpenAI            -> https://api.openai.com/v1
#   OpenRouter        -> https://openrouter.ai/api/v1
#   LM Studio (local) -> http://127.0.0.1:1234/v1
#   Ollama (local)    -> http://127.0.0.1:11434
# Leave blank to use the provider's default.
LLM_BASE_URL=

# Optional tuning
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=180
